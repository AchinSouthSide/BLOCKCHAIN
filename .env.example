# FieldBooking DApp - Environment Variables

# ========== LOCAL DEVELOPMENT (Recommended) ==========
# For local Hardhat development - NO FEES REQUIRED

# Contract address (fill after deployment)
REACT_APP_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Network configuration (31337 = Hardhat Local)
REACT_APP_NETWORK_ID=31337

# Hardhat node RPC (keep default)
REACT_APP_HARDHAT_RPC=http://127.0.0.1:8545


# ========== OPTIONAL: Sepolia Testnet ==========
# Only if you want to test on Sepolia (requires test ETH)

# Sepolia RPC URL (choose one)
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Your wallet private key (ONLY for testnet - NEVER use on mainnet!)
# PRIVATE_KEY=0x...

# Etherscan API key for contract verification
# ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

